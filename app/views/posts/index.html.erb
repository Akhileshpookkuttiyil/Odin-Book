<div class="page-header">
  <h1>All Posts</h1>

  <% if user_signed_in? %>
    <%= link_to "New Post", new_post_path, class: "btn-primary" %>
  <% end %>
</div>

<% @posts.each do |post| %>
  <div class="post">

    <div class="post-header">
      <% if post.user.avatar.attached? %>
        <%= image_tag post.user.avatar, class: "post-avatar" %>
      <% else %>
        <div class="post-avatar-fallback">
          <%= post.user.name[0].upcase %>
        </div>
      <% end %>

      <div class="post-user-info">
        <p class="post-author"><%= post.user.name %></p>
        <p class="post-time"><%= smart_time(post.created_at) %></p>
      </div>
    </div>

    <% if post.body.present? %>
      <p class="post-body"><%= post.body %></p>
    <% end %>

    <% if post.image.attached? %>
      <%= image_tag post.image, class: "post-image" %>
    <% end %>

    <div class="post-stats">
      <span>👍 <%= post.likes.count %> Likes</span>
      <span>💬 <%= post.comments.count %> Comments</span>
    </div>

    <div class="post-actions">
      <%= link_to "View", post_path(post), class: "btn" %>

      <% if user_signed_in? && current_user == post.user %>
        <%= link_to "Delete",
        post_path(post),
        data: {
          turbo_method: :delete,
          turbo_confirm: "Are you sure?"
        },
        class: "btn btn-danger" %>
      <% end %>
    </div>

  </div>
<% end %>