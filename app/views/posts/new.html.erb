<h1>Create New Post</h1>

<%= form_with model: @post do |f| %>
  <div>
    <%= f.label :body, "What's on your mind?" %>
    <%= f.text_area :body, rows: 4 %>
  </div>

  <div>
    <%= f.label :image, "Add a photo (optional)" %>
    <%= f.file_field :image %>
  </div>

  <%= f.submit "Post" %>
<% end %>