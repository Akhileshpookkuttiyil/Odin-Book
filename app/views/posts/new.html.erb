<div class="form-page">
  <div class="form-card">

    <h1>Create Post</h1>

    <%= form_with model: @post do |f| %>

      <div class="form-group">
        <%= f.label :body, "What's on your mind?", class: "form-label" %>

        <%= f.text_area :body,
        rows: 5,
        placeholder: "Share something with your friends..." %>
      </div>

      <div class="form-group">
        <%= f.label :image, "Add Photo", class: "form-label" %>

        <%= f.file_field :image, class: "file-input" %>
      </div>

      <%= f.submit "Create Post", class: "submit-btn" %>

    <% end %>

  </div>
</div>