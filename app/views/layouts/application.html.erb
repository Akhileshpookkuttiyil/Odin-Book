<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Odin Book" %></title>

    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Odin Book">
    <meta name="mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>

      <nav class="navbar">

        <div class="navbar-left">
          <%= link_to "OdinBook", root_path, class: "logo" %>
        </div>

        <div class="navbar-center">
          <%= link_to "Home", root_path, class: "nav-link" %>
          <%= link_to "Posts", posts_path, class: "nav-link" %>
          <%= link_to "People", users_path, class: "nav-link" %>
          <%= link_to "Friends", friendships_path, class: "nav-link" %>
        </div>

        <div class="navbar-right">

  <% if current_user.avatar.attached? %>

    <%= image_tag current_user.avatar,
    class: "navbar-user-avatar" %>

  <% else %>

    <div class="navbar-user-avatar-fallback">
      <%= current_user.name[0].upcase %>
    </div>

  <% end %>

  <span class="navbar-username">
    <%= current_user.name %>
  </span>

  <details class="profile-dropdown">

    <summary class="dropdown-trigger">
      ▼
    </summary>

    <div class="dropdown-menu">

      <%= link_to "My Profile",
      user_path(current_user),
      class: "dropdown-item" %>

      <%= link_to "Sign Out",
      destroy_user_session_path,
      data: {
        turbo_method: :delete
      },
      class: "dropdown-item logout-item" %>

    </div>

  </details>

</div>

      </nav>

    <% end %>

    <% if notice.present? %>
      <p class="notice"><%= notice %></p>
    <% end %>

    <% if alert.present? %>
      <p class="alert"><%= alert %></p>
    <% end %>

    <main class="container">
      <%= yield %>
    </main>

  </body>
</html>