<div class="friends-page">

  <div class="friends-section">

    <div class="section-header">
      <h2>Friend Requests</h2>
      <span class="section-count">
        <%= @friend_requests.count %>
      </span>
    </div>

    <% if @friend_requests.any? %>

      <div class="friends-list">

        <% @friend_requests.each do |user| %>

          <% friendship = Friendship.find_by(
            user: user,
            friend: current_user,
            status: "pending"
          ) %>

          <div class="friend-card">

            <div class="friend-info">

              <% if user.avatar.attached? %>

                <%= image_tag user.avatar, class: "friend-avatar" %>

              <% else %>

                <div class="friend-avatar-fallback">
                  <%= user.name[0].upcase %>
                </div>

              <% end %>

              <div class="friend-details">

                <%= link_to user.name,
                user_path(user),
                class: "friend-name" %>

              </div>

            </div>

            <div class="friend-actions">

              <%= button_to "Accept",
              friendship_path(friendship),
              method: :patch,
              class: "btn" %>

              <%= button_to "Reject",
              friendship_path(friendship),
              method: :delete,
              class: "btn btn-danger" %>

            </div>

          </div>

        <% end %>

      </div>

    <% else %>

      <div class="empty-state">
        No pending friend requests.
      </div>

    <% end %>

  </div>

  <div class="friends-section">

    <div class="section-header">
      <h2>My Friends</h2>
      <span class="section-count">
        <%= @friends.count %>
      </span>
    </div>

    <% if @friends.any? %>

      <div class="friends-list">

        <% @friends.each do |friend| %>

          <% friendship = Friendship.find_by(
            user: current_user,
            friend: friend,
            status: "accepted"
          ) %>

          <div class="friend-card">

            <div class="friend-info">

              <% if friend.avatar.attached? %>

                <%= image_tag friend.avatar, class: "friend-avatar" %>

              <% else %>

                <div class="friend-avatar-fallback">
                  <%= friend.name[0].upcase %>
                </div>

              <% end %>

              <div class="friend-details">

                <%= link_to friend.name,
                user_path(friend),
                class: "friend-name" %>

              </div>

            </div>

            <div class="friend-actions">

              <%= button_to "Unfriend",
              friendship_path(friendship),
              method: :delete,
              data: {
                turbo_confirm: "Are you sure?"
              },
              class: "btn btn-danger" %>

            </div>

          </div>

        <% end %>

      </div>

    <% else %>

      <div class="empty-state">
        You have no friends yet.
      </div>

    <% end %>

  </div>

  <div class="friends-section">

    <div class="section-header">
      <h2>Pending Requests</h2>
      <span class="section-count">
        <%= @pending_requests.count %>
      </span>
    </div>

    <% if @pending_requests.any? %>

      <div class="friends-list">

        <% @pending_requests.each do |friend| %>

          <% friendship = Friendship.find_by(
            user: current_user,
            friend: friend,
            status: "pending"
          ) %>

          <div class="friend-card">

            <div class="friend-info">

              <% if friend.avatar.attached? %>

                <%= image_tag friend.avatar, class: "friend-avatar" %>

              <% else %>

                <div class="friend-avatar-fallback">
                  <%= friend.name[0].upcase %>
                </div>

              <% end %>

              <div class="friend-details">

                <%= link_to friend.name,
                user_path(friend),
                class: "friend-name" %>

                <p class="pending-text">
                  Waiting for response
                </p>

              </div>

            </div>

            <div class="friend-actions">

              <%= button_to "Cancel",
              friendship_path(friendship),
              method: :delete,
              class: "btn btn-danger" %>

            </div>

          </div>

        <% end %>

      </div>

    <% else %>

      <div class="empty-state">
        No pending requests.
      </div>

    <% end %>

  </div>

</div>